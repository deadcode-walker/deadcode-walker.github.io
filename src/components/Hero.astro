---
---

<section class="hero">
  <div class="container">
    <p class="hero-tag">reverse engineer · systems programmer</p>
    <h1 class="hero-title">
      deadcode<br />
      walker<span class="cursor">_</span>
    </h1>
    <p class="hero-sub">
      low-level tooling · c/c++ · rust · x86/x64
    </p>
    <div class="hero-line"></div>
  </div>
</section>

<style>
  .hero {
    padding: 10rem 0 6rem;
    min-height: 90vh;
    display: flex;
    align-items: center;
  }

  .hero-tag {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--fg-muted);
    margin-bottom: 2rem;
    animation: slide-in-left 0.6s ease 0.2s both;
  }

  .hero-title {
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 2rem;
    animation: fade-up 0.8s ease 0.4s both;
  }


  .cursor {
    display: inline-block;
    animation: blink 1s step-end infinite;
    color: var(--fg-muted);
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .hero-sub {
    font-size: 13px;
    color: var(--fg-muted);
    letter-spacing: 0.02em;
    animation: fade-up 0.8s ease 0.6s both;
  }

  .hero-line {
    width: 48px;
    height: 1px;
    background: var(--fg);
    margin-top: 3rem;
    animation: line-grow 0.8s ease 0.8s both;
    transform-origin: left;
  }
</style>
