---
const links = [
  { label: "work", href: "#work" },
  { label: "about", href: "#about" },
  { label: "contact", href: "#contact" },
];
---

<nav>
  <div class="container nav-inner">
    <a href="/" class="logo">◼ dcw</a>
    <div class="nav-links">
      {links.map((link) => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </div>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(250, 250, 250, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    animation: fade-in 0.6s ease;
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 56px;
  }

  .logo {
    font-weight: 700;
    font-size: 15px;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-link {
    font-size: 13px;
    color: var(--fg-muted);
    transition: color 0.2s ease;
    position: relative;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--fg);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s ease;
  }

  .nav-link:hover {
    color: var(--fg);
  }

  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
</style>
